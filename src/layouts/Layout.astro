---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Azedin Barber — Elite Grooming Berja',
  description = 'Barbería en Berja, Almería. Reserva con Azedin o Samir. Fades, cortes de tendencia y arreglo de barba. 5.0★ en Booksy.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />
</head>
<body class="bg-dark-bg text-ink font-jakarta antialiased overflow-x-hidden">
  <slot />

  <script is:inline>
    document.addEventListener('click', function(e) {
      var trigger = e.target.closest('[data-book-trigger]');
      if (!trigger) return;
      window.dispatchEvent(new CustomEvent('book:open', {
        detail: { barber: trigger.dataset.bookBarber || null }
      }));
    });
  </script>
</body>
</html>
