---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Azedin Barber — Elite Grooming Berja',
  description = 'Barbería en Berja, Almería. Reserva con Azedin o Samir. Fades, cortes de tendencia y arreglo de barba. 5.0★ en Booksy.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <slot />

  <script>
    // Global booking-modal controls, used via onclick="" attributes across
    // Header, Hero, Location and BookingModal components.
    function openModal(barber?: string) {
      document.getElementById('modalOverlay')?.classList.add('open');
      if (barber) selectBarber(barber);
    }
    function closeModal() {
      document.getElementById('modalOverlay')?.classList.remove('open');
    }
    function selectBarber(name: string) {
      document.getElementById('tabAzedin')?.classList.toggle('active', name === 'Azedin');
      document.getElementById('tabSamir')?.classList.toggle('active', name === 'Samir');
    }

    // Expose on window so inline onclick="" handlers can reach them.
    (window as any).openModal = openModal;
    (window as any).closeModal = closeModal;
    (window as any).selectBarber = selectBarber;
  </script>
</body>
</html>
