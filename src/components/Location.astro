---
/**
 * Location — Split layout 60/40.
 * Left: address, hours, CTA.
 * Right: Google Maps embed (iframe, tastefully styled).
 *
 * Maps link: https://maps.app.goo.gl/gvjmsWwo8HRToHvi8
 * Maps embed iframe provided by user.
 */
import { business } from '../data/content.js';
import CTA from './CTA.astro';

const mapsLink = 'https://maps.app.goo.gl/gvjmsWwo8HRToHvi8';
const mapsEmbed = 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3193.049605924067!2d-2.945438799999954!3d36.841288!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd7049b3da9d6eed%3A0xa86993085bb7ece!2sAzedin%20Barber!5e0!3m2!1ses!2ses!4v1784059866369!5m2!1ses!2ses';
---

<section
  id="ubicacion"
  class="relative overflow-hidden py-0"
  aria-labelledby="location-heading"
>

  <!-- Section header -->
  <div class="px-6 md:px-10 max-w-6xl mx-auto pt-[clamp(5rem,10vw,8rem)] pb-12">
    <p
      data-fade
      class="text-[10px] tracking-[0.3em] uppercase text-ink-dim font-semibold mb-4 opacity-0"
    >
      Nos encontrarás
    </p>
    <h2
      id="location-heading"
      data-reveal
      class="font-display display-large text-cream opacity-0"
    >
      Encuéntranos
    </h2>
  </div>

  <!-- 60/40 split -->
  <div class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-px bg-border max-w-[100vw] overflow-hidden">

    <!-- Left: Info -->
    <div class="bg-bg-deep px-8 md:px-14 py-14 lg:py-20 flex flex-col justify-between gap-10">

      <!-- Address -->
      <div data-fade class="opacity-0">
        <p class="text-[10px] tracking-[0.25em] uppercase text-ink-faint font-medium mb-3">Dirección</p>
        <address class="not-italic text-cream text-[clamp(1rem,2vw,1.2rem)] leading-relaxed font-medium">
          {business.address}
        </address>
        <a
          href={mapsLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 mt-4 text-[11px] text-steel/60 uppercase tracking-[0.14em] font-semibold hover:text-steel transition-colors duration-180 underline underline-offset-4 decoration-steel-faint"
          aria-label="Cómo llegar a Azedin Barber en Google Maps"
        >
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M6 1a3.5 3.5 0 0 1 3.5 3.5c0 2.5-3.5 6.5-3.5 6.5S2.5 7 2.5 4.5A3.5 3.5 0 0 1 6 1z" stroke="#9BA3AC" stroke-width="1"/>
            <circle cx="6" cy="4.5" r="1" fill="#9BA3AC"/>
          </svg>
          Cómo llegar
        </a>
      </div>

      <!-- Divider -->
      <div class="w-12 h-px bg-border-hi"></div>

      <!-- Hours -->
      <div data-stagger class="flex flex-col gap-3">
        {business.hours.map((h) => (
          <div class="flex items-baseline justify-between gap-4 border-b border-border pb-3 last:border-0 last:pb-0 opacity-0">
            <span class="text-[12px] text-ink-dim font-medium uppercase tracking-wide">{h.day}</span>
            <span class="text-[13px] text-cream font-semibold text-right shrink-0">{h.time}</span>
          </div>
        ))}
      </div>

      <!-- CTA -->
      <div data-fade class="opacity-0">
        <CTA label="Reservar cita" />
      </div>

    </div>

    <!-- Right: Map embed -->
    <div
      data-reveal="right"
      class="relative min-h-[360px] lg:min-h-[520px] overflow-hidden opacity-0"
    >
      <iframe
        src={mapsEmbed}
        title="Mapa de Azedin Barber en Berja, Almería"
        loading="lazy"
        referrerpolicy="strict-origin-when-cross-origin"
        allowfullscreen
        class="absolute inset-0 w-full h-full border-0"
        style="filter: sepia(30%) contrast(0.9) brightness(0.75) hue-rotate(10deg);"
        aria-label="Mapa con la ubicación de Azedin Barber"
      ></iframe>
      <!-- Oak-tinted overlay to blend with palette -->
      <div
        class="absolute inset-0 pointer-events-none"
        style="background: linear-gradient(135deg, rgba(196,149,106,0.05) 0%, transparent 60%); mix-blend-mode: color;"
        aria-hidden="true"
      ></div>
    </div>

  </div>

</section>
