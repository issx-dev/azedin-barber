---
/**
 * Services — Editorial dot-leader price menu.
 *
 * Minimal typographic list: NAME ······· PRICE (DURATION).
 * No cards, no row borders. Flex-based dot leader fills available width.
 * Stagger animation via GSAP data-stagger on scroll.
 */
import { services, business } from '../data/content.js';
---

<section
  id="servicios"
  class="relative overflow-hidden"
  aria-labelledby="servicios-heading"
  style={`padding-block: var(--section-py);`}
>
  <div class="max-w-4xl mx-auto px-6 md:px-10">

    <!-- Header -->
    <div class="mb-16">
      <p
        data-fade
        class="text-[10px] tracking-[0.3em] uppercase text-oak font-semibold mb-4 opacity-0"
      >
        Lo que ofrecemos
      </p>
      <h2
        id="servicios-heading"
        data-reveal
        class="font-display text-section text-cream leading-none opacity-0"
      >
        Servicios
      </h2>
    </div>

    <!-- Service list — dot-leader menu -->
    <div
      data-stagger
      role="list"
      aria-label="Lista de servicios y precios"
      class="flex flex-col gap-0"
    >
      {services.map((service) => (
        <div class="service-row flex items-baseline gap-3 py-5" role="listitem">
          <span class="font-display font-bold text-[13px] tracking-[0.08em] text-cream whitespace-nowrap">
            {service.name.toUpperCase()}
          </span>
          <span
            class="service-dots"
            aria-hidden="true"
          ></span>
          <span class="text-oak font-bold text-[15px] whitespace-nowrap">
            {service.price}
          </span>
          <span class="text-ink-faint text-[11px] whitespace-nowrap">
            {service.time}
          </span>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-14 flex flex-col sm:flex-row items-start sm:items-center gap-5">
      <button
        data-book-trigger
        class="btn-oak"
        aria-label="Reservar cita en Booksy"
      >
        Reservar cita
      </button>
      <p class="text-ink-faint text-[11px] tracking-wide">
        Reserva en segundos a través de Booksy
      </p>
    </div>

  </div>
</section>

<style>
  .service-dots {
    flex: 1;
    min-width: 2ch;
    overflow: hidden;
    white-space: nowrap;
  }
  .service-dots::after {
    content: " ............................................................................";
    color: var(--color-border);
  }
</style>
