---
/**
 * Services — Architectural 1px Steel Matrix on Dark Marble (#0C0A09).
 *
 * Clean architectural list: NAME + TIME stacked on left, PRICE on right.
 * Separated by edge-to-edge 1px steel borders (border-steel-faint).
 */
import { services } from '../data/content.js';
import CTA from './CTA.astro';
---

<section
  id="servicios"
  class="relative overflow-hidden bg-bg-deep text-cream border-t border-steel-faint py-24 sm:py-32"
  aria-labelledby="servicios-heading"
>
  <div class="max-w-4xl mx-auto px-6 md:px-10">

    <!-- Header -->
    <div class="mb-14">
      <p
        data-fade
        class="text-[13px] md:text-[14.5px] tracking-[0.15em] uppercase text-ink-dim font-medium mb-4"
      >
        Lo que ofrecemos
      </p>
      <h2
        id="servicios-heading"
        data-reveal
        class="font-display display-large text-cream"
      >
        Servicios
      </h2>
    </div>

    <!-- Service list — 1px steel matrix -->
    <div
      data-stagger
      role="list"
      aria-label="Lista de servicios y precios"
      class="flex flex-col border-t border-steel-faint"
    >
      {services.map((service) => (
        <div
          class="service-row flex items-center justify-between py-6 border-b border-steel-faint group transition-colors duration-200"
          role="listitem"
        >
          <!-- Left: Name + Duration stacked -->
          <div class="flex flex-col gap-1">
            <span class="font-display font-bold text-lg md:text-xl tracking-tight text-cream group-hover:text-oak transition-colors duration-200">
              {service.name}
            </span>
            <span class="text-steel/70 text-[12px] font-mono tracking-wider">
              {service.time}
            </span>
          </div>

          <!-- Right: Price -->
          <div class="flex items-center gap-6">
            <span class="font-display font-light text-2xl md:text-3xl text-cream tracking-tight">
              {service.price}
            </span>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA (hidden on mobile to maintain single bottom conversion shell) -->
    <div class="mt-14 hidden md:flex items-center gap-6">
      <CTA label="Reservar cita" />
      <p class="text-steel/70 text-[11px] tracking-wide">
        Reserva en segundos a través de Booksy
      </p>
    </div>

  </div>
</section>
