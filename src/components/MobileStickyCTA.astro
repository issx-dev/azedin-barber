---
/**
 * MobileStickyCTA — Floating bottom CTA, visible only on mobile.
 */
import CTA from './CTA.astro';
---
<div
  id="mobile-sticky-cta"
  class="fixed bottom-0 left-0 right-0 p-3.5 z-[90] md:hidden bg-bg-deep/95 backdrop-blur-md border-t border-steel/15 shadow-2xl transition-transform duration-300 ease-out pointer-events-none"
>
  <CTA label="RESERVAR CITA ›" extraClass="w-full shadow-lg pointer-events-auto text-[11px] font-semibold tracking-[0.18em] py-3.5" />
</div>

<script>
  function initMobileCTA() {
    const cta = document.getElementById('mobile-sticky-cta');
    const hero = document.getElementById('hero');
    const locationSection = document.getElementById('ubicacion');

    if (cta) {
      const handleScroll = () => {
        if (window.innerWidth >= 768) return;
        
        const scrollY = window.scrollY;
        const windowHeight = window.innerHeight;
        const heroHeight = hero ? hero.offsetHeight : 500;
        
        // Hide if near the footer
        const docHeight = document.documentElement.scrollHeight;
        const distanceToBottom = docHeight - (scrollY + windowHeight);
        const nearBottom = distanceToBottom < 600;

        if (scrollY > heroHeight && !nearBottom) {
          cta.classList.remove('translate-y-full');
        } else {
          cta.classList.add('translate-y-full');
        }
      };

      window.addEventListener('scroll', handleScroll, { passive: true });
      handleScroll();
      
      document.addEventListener('astro:before-swap', function() {
        window.removeEventListener('scroll', handleScroll);
      }, { once: true });
    }
  }

  // Support Astro transitions and direct loads
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMobileCTA);
  } else {
    initMobileCTA();
  }
</script>
