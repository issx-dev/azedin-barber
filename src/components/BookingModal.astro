---
import { business } from '../data/content.js';
---
<div class="modal-overlay" id="modalOverlay" onclick="if(event.target===this) closeModal()">
  <div class="modal">
    <button class="modal-close" onclick="closeModal()">✕</button>
    <h3>Reserva tu cita</h3>
    <p class="sub">Elige barbero y te llevamos directo a Booksy para confirmar hora.</p>
    <div class="modal-tabs">
      <div class="modal-tab active" id="tabAzedin" onclick="selectBarber('Azedin')">Azedin</div>
      <div class="modal-tab" id="tabSamir" onclick="selectBarber('Samir')">Samir</div>
    </div>
    <a
      class="btn btn-gold"
      href={business.booksyUrl}
      target="_blank"
      rel="noopener"
      id="bookLink"
    >
      Continuar en Booksy →
    </a>
  </div>
</div>
