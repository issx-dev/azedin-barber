---
/**
 * Hero — Fullscreen immersive section.
 *
 * Concept: "Entering the barbershop"
 * - Logo (azedin-logo.jpg) prominent and centered
 * - Workspace photo as full-bleed background with parallax
 * - Wood slat texture overlay (CSS) — from real barbershop panels
 * - Hexagonal SVG accents — from LED floor lights
 * - CTA rect button (editorial, not pill)
 * - data-hero-text targets → staggered entrance via GSAP
 */

import { Image } from 'astro:assets';
import HexPattern from './HexPattern.astro';
import workspaceImg from '../assets/img/barberia-interior-recepcion.jpeg';
import logoSrc from '../assets/img/logo-azedin-barber-transparente.png';
import { business } from '../data/content.js';

// Video path — served from public/ after build copy or referenced via import
// We reference the compiled output path (Astro copies assets/ into _astro/)
const mobileVideoSrc = '/video/instalaciones-mobile.mp4';
---

<section
  id="hero"
  class="relative flex flex-col items-center justify-center min-h-[100dvh] overflow-hidden wood-slats"
  aria-label="Bienvenida"
>
  <!-- ── Background: workspace photo with parallax (desktop) ─────────── -->
  <div class="hero-bg-desktop absolute inset-0 z-0" aria-hidden="true">
    <Image
      src={workspaceImg}
      alt="Interior de Azedin Barber — barbería en Berja"
      widths={[768, 1176, 1920]}
      sizes="100vw"
      quality={88}
      format="webp"
      loading="eager"
      data-parallax="0.18"
      class="w-full h-[115%] object-cover object-center -translate-y-[7.5%]"
      style="filter: sepia(20%) brightness(0.22) contrast(1.1);"
    />
    <!-- Radial glow from center — simulates the studio spotlight feel -->
    <div
      class="absolute inset-0"
      style="background: radial-gradient(ellipse 70% 60% at 50% 40%, rgba(196,149,106,0.06) 0%, transparent 70%), linear-gradient(to bottom, rgba(12,10,9,0.5) 0%, rgba(12,10,9,0.1) 40%, rgba(12,10,9,0.7) 80%, rgba(12,10,9,1) 100%);"
    ></div>
  </div>

  <!-- ── Background: video loop (mobile only, < 768px) ────────────────── -->
  <div class="hero-bg-mobile absolute inset-0 z-0" aria-hidden="true">
    <!--
      poster= uses the static JPEG as placeholder — ensures LCP fires on the image
      BEFORE the video loads, preventing layout shifts.
      autoplay + muted + playsinline = required by browsers for auto-playback.
      preload="none" = video bytes are NOT fetched until JS initiates; keeps initial
      page load fast. We switch to "auto" on mobile via JS after page load.
    -->
    <video
      id="hero-video-mobile"
      class="hero-video w-full h-full object-cover"
      autoplay
      loop
      muted
      playsinline
      preload="metadata"
      aria-hidden="true"
      style="filter: sepia(15%) brightness(0.2) contrast(1.15);"
    >
      <source src={mobileVideoSrc} type="video/mp4" />
    </video>
    <!-- Gradient overlay — same as desktop for consistent CTA legibility -->
    <div
      class="absolute inset-0"
      style="background: radial-gradient(ellipse 70% 60% at 50% 40%, rgba(196,149,106,0.07) 0%, transparent 70%), linear-gradient(to bottom, rgba(12,10,9,0.45) 0%, rgba(12,10,9,0.05) 40%, rgba(12,10,9,0.72) 80%, rgba(12,10,9,1) 100%);"
    ></div>
  </div>

  <!-- ── Hex accents ─────────────────────────────────────────────────── -->
  <HexPattern layout="panel" size="sm" class="absolute top-28 left-4 md:left-10 z-[1] opacity-35" />
  <HexPattern layout="panel" size="sm" class="absolute bottom-16 right-4 md:right-10 z-[1] opacity-25" />

  <!-- ── Main content ────────────────────────────────────────────────── -->
  <div class="relative z-[2] flex flex-col items-center text-center px-6 max-w-2xl mx-auto">

    <!-- Logo / Heading -->
    <h1
      data-hero-text
      class="mb-6 opacity-0"
    >
      <img
        src={logoSrc.src}
        alt="Azedin Barber"
        class="hero-logo-img mx-auto"
        loading="eager"
      />
    </h1>

    <!-- Tagline -->
    <p
      data-hero-text
      class="text-ink-dim text-[13px] md:text-[14px] tracking-[0.22em] uppercase font-medium mb-10 opacity-0"
    >
      Berja · Almería · Barbería artesanal
    </p>

    <!-- CTA group -->
    <div
      data-hero-text
      class="flex flex-col sm:flex-row items-center gap-4 opacity-0"
    >
      <button
        data-book-trigger
        class="btn-oak text-[11px] px-8 py-3.5"
        aria-label="Reservar cita en Booksy"
      >
        Reservar cita
      </button>
      <a
        href="#lookbook"
        class="btn-ghost text-[11px] px-8 py-3.5"
        aria-label="Ver lookbook de cortes"
      >
        Ver cortes
      </a>
    </div>

  </div>

  <!-- ── Scroll indicator ────────────────────────────────────────────── -->
  <div
    class="absolute bottom-10 left-1/2 -translate-x-1/2 z-[2] flex flex-col items-center gap-2"
    aria-hidden="true"
    data-hero-text
    style="opacity:0;"
  >
    <span class="text-ink-faint text-[9px] tracking-[0.3em] uppercase">Scroll</span>
    <div class="w-px h-10 bg-gradient-to-b from-oak-dim to-transparent opacity-60"></div>
  </div>

  <!-- ── Bottom edge: wood slat separator ───────────────────────────── -->
  <div
    class="absolute bottom-0 left-0 right-0 h-px z-[3]"
    style="background: linear-gradient(90deg, transparent 0%, rgba(196,149,106,0.3) 30%, rgba(196,149,106,0.5) 50%, rgba(196,149,106,0.3) 70%, transparent 100%);"
    aria-hidden="true"
  ></div>

</section>

<style>
  .hero-logo-img {
    width: clamp(240px, 45vw, 420px);
    height: auto;
    
    /* Invert black text on white bg to cream, then add soft luxury glow */
    filter: invert(1) drop-shadow(0 0 25px rgba(196, 149, 106, 0.28));
    mix-blend-mode: screen;
    
    transition: transform 300ms var(--ease-out);
  }
  
  .hero-logo-img:hover {
    transform: scale(1.02);
  }

  /* ── Responsive background switching ──────────────────────────────── */
  /* Mobile: show video, hide desktop photo */
  .hero-bg-mobile  { display: block; }
  .hero-bg-desktop { display: none; }

  /* Desktop (≥ 768px): hide video, show static photo */
  @media (min-width: 768px) {
    .hero-bg-mobile  { display: none; }
    .hero-bg-desktop { display: block; }
  }

  /* Fade-in animation for the video — prevents hard cut when it starts */
  .hero-video {
    opacity: 0;
    transition: opacity 0.8s ease;
  }
  .hero-video.ready {
    opacity: 1;
  }
</style>

<script>
  // Fade in the video once it has enough data to play smoothly.
  // This prevents a white flash if the video takes time to decode its first frame.
  const video = document.getElementById('hero-video-mobile') as HTMLVideoElement | null;
  if (video) {
    const makeReady = () => video.classList.add('ready');
    if (video.readyState >= 3) {
      makeReady();
    } else {
      video.addEventListener('canplay', makeReady, { once: true });
      // Safety fallback: show after 1.5s even if canplay never fires
      setTimeout(makeReady, 1500);
    }
  }
</script>
