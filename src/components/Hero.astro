---
/**
 * Hero — Fullscreen immersive section.
 *
 * Concept: "Entering the barbershop"
 * - Logo (azedin-logo.jpg) prominent and centered
 * - Workspace photo as full-bleed background with parallax
 * - Wood slat texture overlay (CSS) — from real barbershop panels
 * - CTA rect button (editorial, not pill)
 * - data-hero-text targets → staggered entrance via GSAP
 */

import { Image, getImage } from 'astro:assets';
import workspaceImg from '../assets/img/barberia-interior-recepcion.jpeg';
import logoSrc from '../assets/img/logo-azedin-barber-transparente.png';
import { business } from '../data/content.js';
import CTA from './CTA.astro';

// Video paths — served from public/ after build copy or referenced via import
const mobileVideoSrc = '/video/instalaciones-mobile.mp4';
const desktopVideoSrc = '/video/instalaciones-desktop.mp4';

// High-quality WebP poster (same 90 quality, 100% visual fidelity, smaller transfer)
const heroPoster = await getImage({ src: workspaceImg, format: 'webp', width: 800, quality: 90 });
---

<section
  id="hero"
  class="relative flex flex-col items-center justify-center min-h-[100dvh] overflow-hidden wood-slats"
  aria-label="Bienvenida"
>
  <!-- ── Background: photo + video (desktop, >= 768px) ───────────────── -->
  <div class="hero-bg-desktop hidden md:block absolute inset-0 z-0" aria-hidden="true">
    <Image
      src={workspaceImg}
      alt="Interior de Azedin Barber — barbería en Berja"
      widths={[768, 1176]}
      sizes="100vw"
      quality={88}
      format="webp"
      loading="eager"
      decoding="sync"
      fetchpriority="high"
      data-parallax="0.18"
      class="w-full h-[115%] object-cover object-center -translate-y-[7.5%]"
      style="filter: sepia(20%) brightness(0.22) contrast(1.1);"
    />
    <video
      id="hero-video-desktop"
      class="hero-video absolute inset-0 w-full h-[115%] object-cover object-center -translate-y-[7.5%]"
      autoplay
      loop
      muted
      playsinline
      preload="metadata"
      poster={heroPoster.src}
      aria-hidden="true"
      style="filter: sepia(20%) brightness(0.22) contrast(1.1);"
      data-parallax="0.18"
    >
      <source src={desktopVideoSrc} type="video/mp4" />
    </video>
    <div
      class="absolute inset-0"
      style="background: radial-gradient(ellipse 70% 60% at 50% 40%, rgba(196,149,106,0.06) 0%, transparent 70%), linear-gradient(to bottom, rgba(12,10,9,0.5) 0%, rgba(12,10,9,0.1) 40%, rgba(12,10,9,0.7) 80%, rgba(12,10,9,1) 100%);"
    ></div>
  </div>

  <!-- ── Background: video loop (mobile only, < 768px) ──────────────── -->
  <div class="hero-bg-mobile block md:hidden absolute inset-0 z-0" aria-hidden="true">
    <video
      id="hero-video-mobile"
      class="hero-video absolute inset-0 w-full h-full object-cover"
      autoplay
      loop
      muted
      playsinline
      preload="metadata"
      poster={heroPoster.src}
      aria-hidden="true"
      style="filter: sepia(15%) brightness(0.2) contrast(1.15);"
    >
      <source src={mobileVideoSrc} type="video/mp4" />
    </video>
    <div
      class="absolute inset-0"
      style="background: radial-gradient(ellipse 70% 60% at 50% 40%, rgba(196,149,106,0.07) 0%, transparent 70%), linear-gradient(to bottom, rgba(12,10,9,0.45) 0%, rgba(12,10,9,0.05) 40%, rgba(12,10,9,0.72) 80%, rgba(12,10,9,1) 100%);"
    ></div>
  </div>

  <!-- ── Main content ────────────────────────────────────────────────── -->
  <div class="relative z-[2] flex flex-col items-center text-center px-6 max-w-2xl mx-auto">

    <!-- Logo / Heading -->
    <h1
      data-hero-text
      class="mb-6"
    >
      <img
        src={logoSrc.src}
        alt=""
        class="hero-logo-img mx-auto"
        loading="eager"
        fetchpriority="high"
        width="500"
        height="333"
        aria-hidden="true"
      />
      <span class="sr-only">Azedin Barber — Barbería en Berja, Almería</span>
    </h1>

    <!-- Tagline -->
    <p
      data-hero-text
      class="text-ink-dim text-[13px] md:text-[14px] tracking-[0.22em] uppercase font-medium mb-10"
    >
      {business.tagline}
    </p>

    <!-- CTA group -->
    <div
      data-hero-text
      class="flex flex-col sm:flex-row items-center gap-4 mb-8"
    >
      <CTA
        label="Reservar cita"
        extraClass="text-[11px] px-8 py-3.5"
      />
      <a
        href="#lookbook"
        class="btn-outline-thin text-[11px] px-8 py-3.5"
      >
        Ver cortes
      </a>
    </div>

    <!-- Trust badge micro-strip -->
    <div data-hero-text class="flex items-center justify-center gap-3 text-[11px] text-steel/80">
      <div class="flex items-center gap-1.5">
        <span class="font-display font-bold text-cream">{business.rating}</span>
        <span class="text-oak font-bold">★</span>
        <span class="text-ink-dim">({business.reviewCount})</span>
      </div>
      <span class="text-border select-none">·</span>
      <span class="text-steel/80">Atención sin esperas</span>
    </div>

  </div>

  <!-- ── Scroll indicator ────────────────────────────────────────────── -->
  <div
    class="absolute bottom-10 left-1/2 -translate-x-1/2 z-[2] flex flex-col items-center gap-2"
    aria-hidden="true"
    data-hero-text
  >
    <span class="text-ink-faint text-[9px] tracking-[0.3em] uppercase">Scroll</span>
    <div class="w-px h-10 bg-gradient-to-b from-steel-dim to-transparent opacity-60"></div>
  </div>

  <!-- ── Bottom edge: steel hairline separator ─────────────────────── -->
  <div
    class="absolute bottom-0 left-0 right-0 h-px z-[3]"
    style="background: linear-gradient(90deg, transparent 0%, rgba(155,163,172,0.3) 30%, rgba(155,163,172,0.5) 50%, rgba(155,163,172,0.3) 70%, transparent 100%);"
    aria-hidden="true"
  ></div>
</section>

<style>
  .hero-logo-img {
    width: clamp(240px, 45vw, 420px);
    height: auto;
    filter: invert(1) drop-shadow(0 0 25px rgba(196, 149, 106, 0.28));
    transition: transform 300ms var(--ease-out);
  }
  
  .hero-logo-img:hover {
    transform: scale(1.02);
  }

  .hero-video {
    opacity: 0;
    transition: opacity 0.8s ease;
  }
  .hero-video.ready {
    opacity: 1;
  }
</style>

<script>
  const videoDesktop = document.getElementById('hero-video-desktop') as HTMLVideoElement | null;
  const videoMobile = document.getElementById('hero-video-mobile') as HTMLVideoElement | null;

  const startVideo = (video: HTMLVideoElement) => {
    const makeReady = () => video.classList.add('ready');
    video.play().then(() => {
      if (video.readyState >= 3) {
        makeReady();
      } else {
        video.addEventListener('canplay', makeReady, { once: true });
      }
    }).catch(err => {
      console.warn("Autoplay was prevented or video load failed:", err);
      makeReady();
    });
  };

  const loadTargetVideo = () => {
    if (window.innerWidth < 768) {
      if (videoMobile) startVideo(videoMobile);
    } else {
      if (videoDesktop) startVideo(videoDesktop);
    }
  };

  if (document.readyState === 'complete') {
    loadTargetVideo();
  } else {
    window.addEventListener('load', loadTargetVideo, { once: true });
  }
</script>
