---
/**
 * Lookbook — Winston Studio Inspired Editorial Catalog.
 *
 * Spacious 3-column portrait grid with clean external captions below each image.
 * Zero overlays covering the haircuts.
 */
import { Image } from 'astro:assets';
import { galleryItems } from '../data/content.js';
import CTA from './CTA.astro';

// Use first 6 curated haircuts for the editorial catalog
const items = galleryItems.slice(0, 6);
---

<section
  id="lookbook"
  class="bg-bg-deep py-0"
  aria-label="Galería de cortes — Lookbook"
>
  <!-- Section header -->
  <div class="px-6 md:px-10 pt-24 pb-14 max-w-6xl mx-auto">
    <p
      data-fade
      class="text-[13px] md:text-[14.5px] tracking-[0.15em] uppercase text-ink-dim font-medium mb-4"
    >
      Nuestro trabajo
    </p>
    <h2
      data-reveal
      class="font-display display-large text-cream"
    >
      Lookbook
    </h2>
  </div>

  <!-- Editorial Catalog Grid -->
  <div class="px-5 sm:px-8 md:px-10 max-w-6xl mx-auto pb-8 md:pb-16">
    <div class="grid grid-cols-2 lg:grid-cols-3 gap-3.5 sm:gap-8 lg:gap-14">
      {items.map((item, index) => {
        const isExtra = index >= 4;
        return (
          <div 
            data-fade 
            class={`lookbook-item group flex flex-col ${isExtra ? 'lookbook-extra hidden md:flex' : ''}`}
          >
            <!-- Portrait photo card -->
            <div class="relative aspect-[3/4] overflow-hidden bg-bg-panel border border-steel/15 rounded-sm">
              <Image
                src={item.src}
                alt={item.alt}
                widths={[320, 480, 640, 960]}
                sizes="(max-width: 640px) 50vw, (max-width: 1024px) 50vw, 33vw"
                quality={88}
                format="webp"
                class="lookbook-img photo-preset w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
                style={`object-position: ${item.focus}`}
              />
            </div>

            <!-- Clean external caption below image (Winston Studio pattern) -->
            <div class="mt-2.5 sm:mt-4 flex items-center justify-between border-b border-steel/20 pb-2">
              <span class="font-display font-semibold text-[11px] sm:text-[14px] text-cream uppercase tracking-wide truncate pr-1">
                {String(index + 1).padStart(2, '0')} / {item.label}
              </span>
              <span class="text-steel/70 text-[9px] sm:text-[11px] font-mono tracking-wider shrink-0">
                {item.barber}
              </span>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Mobile Progressive Expander Button (visible on mobile < 768px) -->
    <div class="text-center pt-8 block md:hidden">
      <button
        id="lookbook-toggle-btn"
        class="btn-outline-thin text-[11px] px-8 py-3.5"
        aria-expanded="false"
      >
        VER MÁS CORTES ›
      </button>
    </div>
  </div>

  <!-- CTA below grid (hidden on mobile to prevent conversion clutter) -->
  <div class="text-center pt-8 pb-16 px-6 hidden md:block">
    <p class="text-ink-dim text-[13px] mb-6">
      Cada corte cuenta su propia historia.
    </p>
    <CTA label="Reserva tu corte" />
  </div>

</section>

<script>
  const toggleBtn = document.getElementById('lookbook-toggle-btn');
  if (toggleBtn) {
    toggleBtn.addEventListener('click', () => {
      const extraItems = document.querySelectorAll('.lookbook-extra');
      const isExpanded = toggleBtn.getAttribute('aria-expanded') === 'true';

      extraItems.forEach((item) => {
        if (isExpanded) {
          item.classList.add('hidden');
        } else {
          item.classList.remove('hidden');
        }
      });

      toggleBtn.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');
      toggleBtn.textContent = isExpanded ? 'VER MÁS CORTES ›' : 'VER MENOS ‹';

      setTimeout(() => {
        if (window.gsap && window.gsap.ScrollTrigger) {
          window.gsap.ScrollTrigger.refresh();
        }
      }, 0);
    });
  }
</script>
