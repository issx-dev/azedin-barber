---
/**
 * Footer — Minimal typographic block.
 *
 * Bricolage Grotesque wordmark + horizontal social/copyright row.
 * No CTA, no logo image.
 */
import { business } from '../data/content.js';
---

<footer class="border-t border-border" role="contentinfo">
  <div class="max-w-6xl mx-auto px-6 md:px-10 py-14 flex flex-col items-center gap-8">

    <!-- Wordmark -->
    <h2 class="footer-wordmark font-black text-[clamp(1.6rem,4vw,2.4rem)] tracking-[-0.04em] text-cream leading-none select-none">
      AZEDIN BARBER
    </h2>

    <!-- Horizontal row: links + copyright -->
    <div class="flex flex-col sm:flex-row items-center gap-3 sm:gap-5 text-[11px] text-ink-faint">
      <nav class="flex items-center gap-4" aria-label="Redes sociales">
        <a
          href={business.instagramUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="uppercase tracking-[0.16em] text-ink-dim hover:text-steel transition-colors duration-180 font-semibold"
          aria-label="Instagram de Azedin Barber"
        >
          Instagram
        </a>
        <span class="text-border-hi">&middot;</span>
        <a
          href={business.tiktokUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="uppercase tracking-[0.16em] text-ink-dim hover:text-steel transition-colors duration-180 font-semibold"
          aria-label="TikTok de Azedin Barber"
        >
          TikTok
        </a>
        <span class="text-border-hi">&middot;</span>
        <a
          href={business.booksyUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="uppercase tracking-[0.16em] text-ink-dim hover:text-steel transition-colors duration-180 font-semibold"
          aria-label="Reservas en Booksy"
        >
          Booksy
        </a>
        <span class="text-border-hi">&middot;</span>
        <a
          href="https://maps.app.goo.gl/gvjmsWwo8HRToHvi8"
          target="_blank"
          rel="noopener noreferrer"
          class="uppercase tracking-[0.16em] text-ink-dim hover:text-steel transition-colors duration-180 font-semibold"
          aria-label="Cómo llegar"
        >
          Cómo llegar
        </a>
      </nav>
      <span class="text-border-hi hidden sm:block">&middot;</span>
      <p class="tracking-wide">
        &copy; {new Date().getFullYear()} Azedin Barber
      </p>
    </div>

  </div>
</footer>



