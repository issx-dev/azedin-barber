---
/**
 * Reviews — Large editorial quotes section.
 *
 * Big decorative quotes (Playfair Display), continuous marquee.
 * No card borders. Text-forward design.
 * Star rating + Booksy badge below.
 * Marquee respects prefers-reduced-motion.
 */
import { reviews, business } from '../data/content.js';
import StarRating from './StarRating.astro';

// Duplicate for seamless loop
const track = [...reviews, ...reviews];
---

<section
  id="reseñas"
  class="relative overflow-hidden py-[clamp(5rem,10vw,8rem)]"
  aria-labelledby="reviews-heading"
>

  <!-- Header -->
  <div class="px-6 md:px-10 max-w-4xl mx-auto mb-16">
    <p
      data-fade
      class="text-[10px] tracking-[0.3em] uppercase text-oak font-semibold mb-4 opacity-0"
    >
      Lo que dicen
    </p>
    <h2
      id="reviews-heading"
      data-reveal
      class="font-display text-section text-cream leading-none opacity-0"
    >
      Reseñas
    </h2>
  </div>

  <!-- Marquee track -->
  <div
    class="relative overflow-hidden"
    aria-label="Carrusel de reseñas"
  >
    <!-- Fade edges -->
    <div
      class="absolute left-0 top-0 bottom-0 w-24 z-[2] pointer-events-none"
      style="background: linear-gradient(to right, var(--color-bg-deep), transparent);"
      aria-hidden="true"
    ></div>
    <div
      class="absolute right-0 top-0 bottom-0 w-24 z-[2] pointer-events-none"
      style="background: linear-gradient(to left, var(--color-bg-deep), transparent);"
      aria-hidden="true"
    ></div>

    <!-- Scrolling track -->
    <div class="marquee-track flex gap-8 w-max py-2">
      {track.map((review, i) => (
        <article
          class="shrink-0 w-[min(88vw,480px)] border-l border-border-hi pl-7"
          aria-label={`Reseña de cliente: ${review.service} con ${review.barber}`}
        >
          <!-- Decorative quote mark -->
          <span
            class="font-display text-[5rem] text-oak leading-none select-none"
            style="opacity: 0.18; line-height: 0.7; display: block; margin-bottom: 0.5rem;"
            aria-hidden="true"
          >
            &ldquo;
          </span>
          <!-- Quote text -->
          <blockquote class="font-display text-[clamp(1.1rem,2.5vw,1.4rem)] text-cream leading-snug tracking-[-0.01em] mb-5">
            {review.quote}
          </blockquote>
          <!-- Meta -->
          <footer class="flex items-center gap-3">
            <span
              class="text-[10px] uppercase tracking-[0.18em] font-semibold text-oak"
            >
              {review.barber}
            </span>
            <span class="text-border-hi text-[10px]">·</span>
            <span class="text-[11px] text-ink-dim">
              {review.service}
            </span>
          </footer>
        </article>
      ))}
    </div>
  </div>

  <!-- Rating badge -->
  <div class="px-6 md:px-10 max-w-4xl mx-auto mt-16">
    <div
      data-fade
      class="flex flex-col sm:flex-row items-start sm:items-center gap-5 opacity-0"
    >
      <!-- Stars -->
      <StarRating count={5} size={16} />
      <!-- Rating number -->
      <span class="font-display text-cream text-2xl font-bold">{business.rating}</span>
      <!-- Review count -->
      <span class="text-ink-dim text-[12px]">{business.reviewCount}</span>
      <!-- Booksy link -->
      <a
        href={business.booksyUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-[11px] text-oak hover:text-oak-light transition-colors duration-180 uppercase tracking-[0.14em] font-semibold underline underline-offset-4 decoration-oak-dim"
        aria-label="Ver todas las reseñas en Booksy"
      >
        Ver en Booksy →
      </a>
    </div>
  </div>

</section>
