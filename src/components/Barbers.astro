---
/**
 * Barbers — Editorial section below the Hero.
 *
 * Two barbers presented as full-height columns. On scroll:
 * - clip-path reveal: inset(0 0 100% 0) → inset(0) (bottom-up curtain)
 * - BN→color filter: grayscale(100%) → grayscale(0%)
 * Both transitions via data-color-reveal in animations.js
 *
 * No barbers in the Hero (avoids the "tosco" feel of two giant faces).
 * This section acts as a deliberate slow reveal: "meet who's waiting for you."
 */

import { Image } from 'astro:assets';
import personaAzedin from '../assets/img/barbero-azedin-berja.jpeg';
import personaSamir from '../assets/img/barbero-samir-berja.jpeg';
import CTA from './CTA.astro';

const barbers = [
  {
    name:    'Azedin',
    role:    'Fundador',
    title:   'Master Barber',
    desc:    'Más de una década perfeccionando cada degradado, cada arreglo. La precisión es su lenguaje.',
    img:     personaAzedin,
    alt:     'Azedin, fundador y master barber de Azedin Barber en Berja',
  },
  {
    name:    'Samir',
    role:    'Especialista',
    title:   'Barber Specialist',
    desc:    'Manos expertas, ojo para el detalle. Cada corte es una firma personal.',
    img:     personaSamir,
    alt:     'Samir, barber specialist de Azedin Barber en Berja',
  },
];
---

<section
  id="barberos"
  class="relative bg-bg-deep"
  aria-label="Conoce a los barberos"
>
  <!-- Section header -->
  <div class="px-6 md:px-10 pt-24 pb-12 max-w-6xl mx-auto">
    <p
      data-fade
      class="text-[13px] md:text-[14.5px] tracking-[0.15em] uppercase text-ink-dim font-medium mb-4"
    >
      El equipo
    </p>
    <h2
      data-reveal
      class="font-display display-large text-cream"
    >
      Quién te espera
    </h2>
  </div>

  <!-- Barber columns — Raven Barbers Inspired Architecture -->
  <div class="px-6 md:px-10 max-w-6xl mx-auto pb-20">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
      {barbers.map((barber) => (
        <button
          type="button"
          class="barber-card group relative block text-left w-full bg-bg-deep overflow-hidden cursor-pointer border-0 p-0"
          data-book-trigger
          data-book-barber={barber.name}
          aria-label={`RESERVAR CON ${barber.name}`}
        >
          <div class="relative aspect-[3/4] overflow-hidden bg-bg-panel border border-steel/15 rounded-sm">
            <Image
              src={barber.img}
              alt={barber.alt}
              widths={[480, 800, 1200, 1600]}
              sizes="(max-width: 768px) 100vw, 50vw"
              quality={90}
              format="webp"
              loading="lazy"
              data-color-reveal
              class="barber-portrait-img w-full h-full object-cover transition-all duration-500 ease-out"
              style="object-position: center 18%;"
            />
            <!-- Gradient overlay for crisp typographic legibility -->
            <div
              class="absolute inset-0 pointer-events-none bg-gradient-to-t from-bg-deep via-bg-deep/20 to-transparent opacity-95"
            ></div>

            <!-- Barber Raven-style trigger overlay at bottom -->
            <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8 z-10">
              <div class="flex flex-col gap-1 border-b border-steel/30 pb-3">
                <span class="text-[10px] tracking-[0.25em] text-steel uppercase font-medium">
                  RESERVAR CON
                </span>
                <div class="flex items-center justify-between">
                  <h3 class="font-display text-3xl sm:text-4xl text-cream font-bold group-hover:text-oak transition-colors duration-300">
                    {barber.name}
                  </h3>
                  <span class="text-cream text-2xl group-hover:translate-x-1.5 transition-transform duration-300">
                    ›
                  </span>
                </div>
              </div>
            </div>
          </div>
        </button>
      ))}
    </div>
  </div>
</section>

<style>
  .barber-portrait-img {
    filter: grayscale(100%) contrast(1.1) brightness(0.9);
  }
  @media (hover: hover) and (pointer: fine) {
    .group:hover .barber-portrait-img {
      filter: grayscale(0%) saturate(0.85) contrast(1.05) brightness(0.95);
    }
  }
</style>
