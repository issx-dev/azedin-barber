---
/**
 * Header — Fixed nav with logo, desktop links, CTA, and mobile hamburger.
 * Transitions from transparent to blur+dark after 60px scroll.
 *
 * The logo uses the actual azedin-logo.jpg (small, 2.9KB) — displays it
 * at a tasteful size in the header. We treat it as a raster logo since
 * vectorizing in Astro build is complex.
 */
import logoSrc from '../assets/img/new-logo-no-bg.png';

const navLinks = [
  { href: '#lookbook',  label: 'Lookbook'  },
  { href: '#servicios', label: 'Servicios' },
  { href: '#reseñas',   label: 'Reseñas'   },
  { href: '#ubicacion', label: 'Ubicación' },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-[100] transition-[background-color,backdrop-filter] duration-300"
  style="transition-timing-function: var(--ease-out);"
>
  <div class="flex items-center justify-between px-6 md:px-10 h-[68px]">

    <!-- Logo -->
    <a href="#hero" class="flex items-center group" aria-label="Azedin Barber — Inicio">
      <img
        src={logoSrc.src}
        alt="Azedin Barber"
        class="nav-logo-img"
        loading="eager"
      />
    </a>

    <!-- Desktop navigation -->
    <nav class="hidden md:flex items-center gap-8" aria-label="Navegación principal">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="text-[11px] uppercase tracking-[0.16em] font-semibold text-ink-dim hover:text-cream transition-colors duration-180"
          style="transition-timing-function: var(--ease-out);"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- CTA + hamburger -->
    <div class="flex items-center gap-4">
      <button
        data-book-trigger
        class="btn-oak hidden md:inline-flex text-[10px] px-5 py-2.5"
        aria-label="Reservar cita"
      >
        Reservar cita
      </button>

      <!-- Mobile hamburger -->
      <button
        data-nav-trigger
        class="md:hidden flex flex-col gap-[5px] p-2 cursor-pointer bg-transparent border-none"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <span class="block w-5 h-[1.5px] bg-cream transition-transform duration-200"></span>
        <span class="block w-5 h-[1.5px] bg-cream transition-transform duration-200"></span>
        <span class="block w-3 h-[1.5px] bg-cream transition-transform duration-200 self-start"></span>
      </button>
    </div>

  </div>

  <!-- Bottom separator line -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border to-transparent opacity-0 transition-opacity duration-300" id="header-line"></div>
</header>

<script is:inline>
  // Show header separator line after scroll
  var headerLine = document.getElementById('header-line');
  if (headerLine) {
    window.addEventListener('scroll', function() {
      if (window.scrollY > 60) {
        headerLine.style.opacity = '1';
      } else {
        headerLine.style.opacity = '0';
      }
    }, { passive: true });
  }
</script>

<style>
  .nav-logo-img {
    width: 110px;
    height: auto;
    
    /* Invert black text on white bg to white text on black, then make black transparent */
    filter: invert(1);
    mix-blend-mode: screen;
    
    opacity: 0.94;
    transition: opacity 200ms var(--ease-out), transform 200ms var(--ease-out);
  }
  
  .nav-logo-img:hover {
    opacity: 1;
    transform: scale(1.03);
  }
</style>
