---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Barbers from '../components/Barbers.astro';
import Lookbook from '../components/Lookbook.astro';
import Services from '../components/Services.astro';
import Reviews from '../components/Reviews.astro';
import Location from '../components/Location.astro';
import Footer from '../components/Footer.astro';
import About from '../components/About.astro';
import InstagramStrip from '../components/InstagramStrip.astro';
import BookingModal from '../components/BookingModal.jsx';
import MobileNav from '../components/MobileNav.jsx';
import StarRating from '../components/StarRating.astro';
import { business, barberImgs } from '../data/content.js';
import logoSrc from '../assets/img/logo-azedin-barber-transparente.png';
---

<Layout>
  <Header />

  <main id="main-content">
    <Hero />
    <Barbers />

    <!-- Trust strip: rating between Barbers and Lookbook -->
    <div class="border-y border-border py-5 overflow-hidden bg-bg-panel">
      <div class="flex items-center justify-center gap-4 px-6 text-center flex-wrap">
        <StarRating count={5} size={13} />
        <span class="font-display text-cream font-bold text-lg">{business.rating}</span>
        <span class="text-border-hi select-none">·</span>
        <span class="text-ink-dim text-[12px]">{business.reviewCount}</span>
        <span class="text-border-hi select-none hidden sm:inline">·</span>
        <a
          href={business.booksyUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[11px] uppercase tracking-[0.14em] font-semibold text-steel/60 hover:text-steel transition-colors duration-180"
          aria-label="Ver perfil en Booksy"
        >
          Booksy
        </a>
      </div>
    </div>

    <Lookbook />
    <Services />
    <Reviews />
    <About />
    <Location />
    <InstagramStrip />
  </main>

  <Footer />

  <!-- Interactive Elements -->
  <BookingModal
    client:load
    booksyUrl={business.booksyUrl}
    barbers={[
      { name: 'Azedin', img: barberImgs.Azedin.src.src },
      { name: 'Samir', img: barberImgs.Samir.src.src }
    ]}
  />
  <MobileNav
    client:load
    logoSrc={logoSrc.src}
  />
</Layout>

