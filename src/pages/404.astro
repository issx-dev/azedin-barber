---
import Layout from '../layouts/Layout.astro';
---
<Layout title="404 — Página no encontrada | Azedin Barber" description="La página que buscas no existe.">
  <main id="main-content" class="min-h-screen bg-bg-deep flex flex-col items-center justify-center text-center px-6">
    <p class="text-oak font-display text-[clamp(6rem,20vw,12rem)] font-bold leading-none" aria-hidden="true">404</p>
    <h1 class="font-display text-ink text-[clamp(1.5rem,4vw,2.5rem)] mt-4 mb-6">Página no encontrada</h1>
    <p class="text-ink-faint max-w-md mb-10">El corte que buscas no está en nuestra agenda. Vuelve al inicio y reserva tu cita.</p>
    <a href="/" class="btn-oak">Volver al inicio</a>
  </main>
</Layout>
